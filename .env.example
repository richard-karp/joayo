# ─── joayo backend environment ───────────────────────────────────────────────
# Copy to .env for local dev, or set these as secrets on your host (e.g. Fly.io).

# Claude extraction — REQUIRED for extraction.
ANTHROPIC_API_KEY=

# Instagram / YouTube scraping in the cloud — use Apify (managed, residential
# proxies). REQUIRED for extraction when deployed; replaces browser cookies,
# which do not work reliably from datacenter IPs.
APIFY_API_TOKEN=

# Korean geocoding (Kakao Developers REST key) — REQUIRED to place pins.
KAKAO_REST_API_KEY=

# Reel audio → transcript via Groq's hosted Whisper (whisper-large-v3). OPTIONAL:
# without it, extraction falls back to caption-only (transcript_missing=True).
# Groq's free tier is rate-limited, not credit-limited (permanently free at low
# volume). Get a key at https://console.groq.com
GROQ_API_KEY=
# OPTIONAL overrides: model (whisper-large-v3 | whisper-large-v3-turbo) and the
# minimum seconds between transcription requests (free-tier throttle; 4s ≈ 15/min,
# under Groq's 20/min cap). Defaults are fine.
# GROQ_WHISPER_MODEL=whisper-large-v3
# GROQ_MIN_REQUEST_INTERVAL=4.0

# Shared access code that gates /api/extract (and job resume). When set, callers
# must send it as the X-Extract-Secret header. Leave UNSET locally to keep
# extraction open. SET THIS in production so strangers can't spend your budget.
EXTRACT_SECRET=

# Protects /api/admin/* maintenance endpoints (X-Admin-Token header).
ADMIN_TOKEN=

# Comma-separated allowed CORS origins. Defaults to http://localhost:3000.
# In production set to your deployed frontend, e.g. https://joayo.vercel.app
CORS_ORIGINS=http://localhost:3000

# ─── Local-dev only (NOT for production) ─────────────────────────────────────
# yt-dlp cookies file for fetching Instagram from your own machine. Do not use
# in the cloud — Instagram blocks datacenter IPs and cookies expire.
# INSTAGRAM_COOKIES_FILE=instagram-cookies.txt
# INSTAGRAM_USERNAME=
# INSTAGRAM_PASSWORD=

# ─── Frontend (set in Vercel / frontend/.env.local) ──────────────────────────
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.fly.dev
