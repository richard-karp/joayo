# Keep the image lean and the seed clean.
venv/
.venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
tests/
*.log
.env
.env.*

# Bake places.db AND its -wal sidecar (so uncheckpointed data isn't lost — SQLite
# replays the WAL on first open). Exclude the regenerated -shm and local backups.
places.db-shm
places.db.*
